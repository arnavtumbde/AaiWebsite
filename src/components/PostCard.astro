---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  slug: string;
  imageUrl: string;
  category: string;
}

const { title, excerpt, date, slug, imageUrl, category } = Astro.props;

// Constant author avatar
const authorAvatar = "/p1.png";
---

<article class="group flex flex-col gap-4">
  <a href={`/blog/${slug}`} class="block overflow-hidden rounded-2xl aspect-[4/3] bg-slate-100">
    <img 
      src={imageUrl} 
      alt={title} 
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </a>
  
  <div class="space-y-3">
    <div class="flex items-center gap-3 text-sm text-slate-gray">
      <span class="text-warm-rust font-medium uppercase tracking-wider text-xs">{category}</span>
      <span>&bull;</span>
      <div class="flex items-center gap-2">
        <img src={authorAvatar} alt="Author" class="w-5 h-5 rounded-full object-cover" />
        <time datetime={date}>{date}</time>
      </div>
    </div>
    
    <a href={`/blog/${slug}`} class="block group-hover:text-warm-rust transition-colors duration-300">
      <h3 class="text-2xl font-bold leading-snug">{title}</h3>
    </a>
    
    <p class="text-slate-gray line-clamp-2 leading-relaxed">
      {excerpt}
    </p>
  </div>
</article>
